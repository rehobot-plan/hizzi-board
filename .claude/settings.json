{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "LS",
      "Task",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run lint)",
      "Bash(npm install --save-dev *)",
      "Bash(npx playwright *)",
      "Bash(npx vercel *)",
      "Bash(node .claude/commands/*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git merge*)",
      "Bash(git stash*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(firebase deploy*)",
      "Bash(rm -rf*)",
      "Write(.env*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(npm install)",
      "Bash(npm install *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File scripts/preflight.ps1"
          }
        ]
      }
    ]
  }
}
