rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    match /panels/{panelId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    match /calendarEvents/{eventId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /leaveSettings/{settingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /leaveEvents/{eventId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /todoRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}